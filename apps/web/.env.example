# Exposed to the browser — API base URL. See context/code-standards.md.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Exposed to the browser — canonical site URL, used to resolve metadata
# (Open Graph/Twitter images) on the public landing page. See context/code-standards.md.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Exposed to the browser — deliberately public demo credentials for the landing page's
# "Try the demo" button (feature 36). Not secrets — see context/code-standards.md.
NEXT_PUBLIC_DEMO_EMAIL=demo@subtrack.dev
NEXT_PUBLIC_DEMO_PASSWORD=
