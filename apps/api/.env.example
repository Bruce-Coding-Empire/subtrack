# development | production — gates Swagger (main.ts) and the refresh-token cookie's SameSite value (auth.controller.ts)
NODE_ENV=development

# Server port — api-contract.md documents http://localhost:8000 as the dev base URL
PORT=8000

# Web app origin allowed to call this API with credentials (CORS) — see main.ts
WEB_APP_URL=http://localhost:3000

# Postgres connection string
DATABASE_URL=

# true whenever DATABASE_URL points at a connection requiring TLS — e.g. Neon in production
# (Neon always requires SSL) or running a migration from a laptop against it. Local Postgres doesn't need this.
DATABASE_SSL=false

# JWT secrets — see context/library-docs.md for token issuance pattern
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# Refresh token cookie lifetime in ms — must match the refresh JWT's expiresIn ("7d") in auth.service.ts
REFRESH_TOKEN_MAX_AGE_MS=604800000

# open.er-api.com base URL (free, keyless, full ISO 4217 coverage incl. RWF) — see context/library-docs.md
EXCHANGE_RATE_API_URL=https://open.er-api.com/v6

# Google Cloud OAuth client (Gmail readonly scope) — see context/library-docs.md's Google OAuth section
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/integrations/gmail/callback

# AES-256-GCM key (32 bytes, hex-encoded) used to encrypt stored Gmail OAuth tokens — see common/utils/encryption.util.ts
TOKEN_ENCRYPTION_KEY=

# Machine secret for POST /jobs/* triggers (feature 35) — long/random; must match the
# GitHub Actions repo secret of the same name. Checked timing-safe by JobTriggerGuard.
JOB_TRIGGER_SECRET=

# Demo account (feature 36) — identifies the one user `seed:demo` / POST /jobs/demo/reset
# wipes and reseeds. The password is deliberately not sensitive (it's public on the
# landing page via NEXT_PUBLIC_DEMO_PASSWORD) — see code-standards.md's note.
DEMO_USER_EMAIL=demo@subtrack.dev
DEMO_USER_PASSWORD=
