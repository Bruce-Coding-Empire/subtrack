# Server port — api-contract.md documents http://localhost:3001 as the dev base URL
PORT=3001

# Web app origin allowed to call this API with credentials (CORS) — see main.ts
WEB_APP_URL=http://localhost:3000

# Postgres connection string
DATABASE_URL=

# JWT secrets — see context/library-docs.md for token issuance pattern
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# Refresh token cookie lifetime in ms — must match the refresh JWT's expiresIn ("7d") in auth.service.ts
REFRESH_TOKEN_MAX_AGE_MS=604800000

# exchangerate.host base URL — see context/library-docs.md
EXCHANGE_RATE_API_URL=https://api.exchangerate.host
